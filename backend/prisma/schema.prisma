generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  location    String
  date        DateTime?
  price       Float?
  image       String?
  qrCode      String?
  createdAt   DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  tickets Ticket[]
}